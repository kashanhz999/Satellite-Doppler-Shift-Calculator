# Database (PostgreSQL)
DOPPLER_DATABASE_URL=postgresql+asyncpg://doppler:doppler@localhost:5432/doppler

# Redis
DOPPLER_REDIS_URL=redis://localhost:6379/0

# API Authentication (comma-separated, empty = disabled)
DOPPLER_API_KEYS=

# Celestrak
DOPPLER_CELESTRAK_BASE_URL=https://celestrak.org

# TLE Management
DOPPLER_TLE_REFRESH_INTERVAL_MINUTES=30
DOPPLER_TLE_STALE_THRESHOLD_HOURS=48

# Logging
DOPPLER_LOG_LEVEL=INFO

# CORS origins (comma-separated)
DOPPLER_CORS_ORIGINS=["*"]

# Cache TTL in seconds
DOPPLER_CACHE_TTL_SECONDS=0.5

# Server
DOPPLER_HOST=0.0.0.0
DOPPLER_PORT=8000
